rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      // For this app, we'll allow all signed in users for simplicity in dev
      // but ideally we check email_verified.
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'displayName', 'role']) 
        && data.email is string && data.email.size() <= 200
        && data.displayName is string && data.displayName.size() <= 100
        && data.role in ['customer', 'barber', 'admin'];
    }

    function isValidQueue(data) {
      return data.keys().hasAll(['barberId', 'shopId'])
        && data.barberId is string && data.barberId.size() <= 128
        && data.shopId is string && data.shopId.size() <= 128;
    }

    function isValidQueueEntry(data) {
      return data.keys().hasAll(['customerId', 'customerName', 'status', 'joinedAt'])
        && data.customerName is string && data.customerName.size() <= 100
        && data.status in ['waiting', 'in-progress', 'completed', 'cancelled']
        && ('cancelledReason' in data ? data.cancelledReason is string : true)
        && data.joinedAt is string;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['barberId', 'serviceName', 'price', 'createdAt', 'status', 'customerId'])
        && data.serviceName is string
        && data.price is number
        && data.status in ['upcoming', 'completed', 'cancelled', 'confirmed']
        && ('customerName' in data ? data.customerName is string : true)
        && data.createdAt is string;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['customerId', 'customerName', 'rating', 'createdAt'])
        && data.customerId == request.auth.uid
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.createdAt is string;
    }

    // --- Match Blocks ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update: if isVerified() && userId == request.auth.uid && isValidUser(incoming());
    }

    match /barbers/{barberId} {
      allow read: if true;
      allow create, update: if isVerified() && barberId == request.auth.uid;

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isVerified() && isValidReview(incoming());
      }
    }

    function isBarber() {
      return isVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'barber';
    }

    match /queues/{queueId} {
      allow read: if true;
      allow create: if isVerified() && isValidId(queueId) && incoming().barberId == request.auth.uid && isValidQueue(incoming());
      allow update: if isVerified() && isValidId(queueId) && (
        incoming().barberId == request.auth.uid || 
        get(/databases/$(database)/documents/queues/$(queueId)).data.barberId == request.auth.uid ||
        isBarber()
      );

      match /customers/{entryId} {
        allow read: if true;
        allow create: if isVerified() && isValidId(entryId) && incoming().customerId == request.auth.uid && isValidQueueEntry(incoming());
        allow update: if isVerified() && isValidId(entryId) && (
          // Customer can update their own entry
          (existing().customerId == request.auth.uid && incoming().customerId == existing().customerId) ||
          // Barber who owns the queue or any barber (for shared shops) can manage entries
          ((get(/databases/$(database)/documents/queues/$(queueId)).data.barberId == request.auth.uid || isBarber()) && 
           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'completedAt', 'cancelledReason']))
        );
      }
    }

    match /bookings/{bookingId} {
      allow list, get: if isVerified() && (resource.data.barberId == request.auth.uid || resource.data.customerId == request.auth.uid);
      allow create: if isVerified() && isValidId(bookingId) && (incoming().barberId == request.auth.uid || incoming().customerId == request.auth.uid) && isValidBooking(incoming());
      allow update: if isVerified() && (resource.data.barberId == request.auth.uid || resource.data.customerId == request.auth.uid)
                       && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'cancelledAt', 'appointmentDate']);
    }

    match /notifications/{notificationId} {
      allow read, update: if isVerified() && resource.data.userId == request.auth.uid;
      allow create: if isVerified();
    }

    match /_connection_test_/{docId} {
      allow read: if true;
    }
  }
}
