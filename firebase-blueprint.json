{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "barber", "admin"] },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "displayName", "role"]
    },
    "Queue": {
      "title": "Queue",
      "description": "A live queue for a shop or barber",
      "type": "object",
      "properties": {
        "barberId": { "type": "string" },
        "shopId": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["barberId", "shopId"]
    },
    "QueueEntry": {
      "title": "Queue Entry",
      "description": "An entry in a queue",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "in-progress", "completed"] },
        "joinedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "position": { "type": "number" }
      },
      "required": ["customerId", "customerName", "status", "joinedAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Appointment booking details for analytics and history",
      "type": "object",
      "properties": {
        "barberId": { "type": "string" },
        "serviceName": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "upcoming", "completed", "cancelled", "confirmed", "rejected", "accepted"] },
        "appointmentDate": { "type": "string" },
        "createdAt": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["shop", "home"] },
        "address": { "type": "string" },
        "cancelledAt": { "type": "string" }
      },
      "required": ["barberId", "serviceName", "price", "createdAt", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "A review for a barber",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "customerName", "rating", "createdAt"]
    },
    "BarberProfile": {
      "title": "Barber Profile",
      "description": "Extended profile for barber users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "available": { "type": "boolean" },
        "specialties": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["userId", "displayName"]
    },
    "Service": {
      "title": "Service",
      "description": "Service menu items",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "durationMinutes": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "price", "durationMinutes", "category"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Global users collection"
    },
    "/barbers/{barberId}": {
      "schema": "BarberProfile",
      "description": "Barber profiles"
    },
    "/barbers/{barberId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews for a specific barber"
    },
    "/queues/{queueId}": {
      "schema": "Queue",
      "description": "Active queues"
    },
    "/queues/{queueId}/customers/{entryId}": {
      "schema": "QueueEntry",
      "description": "Customers in a specific queue"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Booking records for history and analytics"
    },
    "/notifications/{notificationId}": {
      "schema": "object",
      "description": "System alerts and notifications"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Available service items"
    }
  }
}
