{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile for both customers and barbers",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "barber"] },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Service": {
      "title": "Service",
      "description": "A grooming service offered by the barber shop",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "durationMinutes": { "type": "integer" },
        "category": { "type": "string" }
      },
      "required": ["name", "price", "durationMinutes"]
    },
    "Barber": {
      "title": "Barber",
      "description": "Extended profile for barber users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "bio": { "type": "string" },
        "specialties": { "type": "array", "items": { "type": "string" } },
        "available": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "integer" }
      },
      "required": ["userId", "available"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A scheduled appointment between a customer and a barber",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "barberId": { "type": "string" },
        "serviceId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "totalPrice": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "barberId", "serviceId", "startTime", "endTime", "status", "totalPrice", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Public and private user profile data"
    },
    "/services/{serviceId}": {
      "schema": { "$ref": "#/entities/Service" },
      "description": "Services offered by the shop"
    },
    "/barbers/{barberId}": {
      "schema": { "$ref": "#/entities/Barber" },
      "description": "Barber-specific profiles and metadata"
    },
    "/bookings/{bookingId}": {
      "schema": { "$ref": "#/entities/Booking" },
      "description": "Appointment bookings"
    }
  }
}
